# ── Server ───────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ── Database (ONE Postgres instance for the whole monolith) ────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hirehelp

# ── Staff auth (recruiter / interviewer / admin) ────────────────────────────
JWT_SECRET=change-me-staff-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Candidate auth — MUST be a different secret from JWT_SECRET above ──────
CANDIDATE_JWT_SECRET=change-me-candidate-secret
CANDIDATE_JWT_EXPIRES_IN=7d

# ── AI evaluation service (the one service that stays separate) ────────────
AI_EVALUATION_SERVICE_URL=http://localhost:8000

# ── Resume storage (S3 / MinIO) ─────────────────────────────────────────────
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=hirehelp-resumes

LOG_LEVEL=info
