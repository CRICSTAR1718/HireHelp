{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "./dist",
    "rootDir": "./server",
    "baseUrl": "./server",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["server/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}
